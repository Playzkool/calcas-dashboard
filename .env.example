# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=calcas
POSTGRES_USER=calcas
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Django ────────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change_me_with_a_50_char_random_string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost

# ── Email ─────────────────────────────────────────────────────────────────────
# URL publique de l'application (utilisée dans les liens des e-mails d'invitation)
SITE_URL=https://votre-domaine.fr
# En développement : laisser la valeur par défaut (les emails s'affichent dans la console Django)
# En production : configurer un serveur SMTP réel pour que les e-mails d'invitation fonctionnent
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@votre-domaine.fr
EMAIL_HOST=smtp.votre-domaine.fr
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@votre-domaine.fr
EMAIL_HOST_PASSWORD=change_me
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
